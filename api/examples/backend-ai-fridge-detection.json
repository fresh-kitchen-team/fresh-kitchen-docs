{
  "endpoint": {
    "method": "POST",
    "path": "/internal/v1/fridge-detection"
  },
  "request": {
    "headers": {
      "Content-Type": "multipart/form-data",
      "Authorization": "Bearer {aiServerToken}",
      "X-Request-Id": "{uuid}"
    },
    "parts": {
      "file": {
        "filename": "fridge.jpg",
        "contentType": "image/jpeg"
      }
    }
  },
  "response": {
    "items": [
      "우유",
      "양파"
    ],
    "detected_items": [
      {
        "name": "우유"
      },
      {
        "name": "양파"
      }
    ]
  }
}
